# ── SecureAuth Environment Variables ──
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB — use a local URI or a MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/secureauth

# JWT — CHANGE THIS to a long, random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string

# Token lifetime (e.g. 3d, 24h, 60m)
JWT_EXPIRES_IN=3d

# Allowed Origins(Add your domains)
ALLOWED_ORIGINS=https://secureauth.giftedtech.co.ke,http://localhost:5000,https://yourdomain.com